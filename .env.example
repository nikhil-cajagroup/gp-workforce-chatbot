# ═══════════════════════════════════════════════════════════════
# GP Workforce Chatbot — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# LOCAL development: set AWS_PROFILE to your named profile
# AWS deployment:    leave AWS_PROFILE blank (IAM Role is used)
# ═══════════════════════════════════════════════════════════════

# ── AWS Credentials ──────────────────────────────────────────
# LOCAL ONLY: which AWS CLI profile to use (from ~/.aws/credentials)
# On AWS (Elastic Beanstalk / ECS / EC2): leave this BLANK — the
# IAM Role attached to the instance provides credentials automatically.
AWS_PROFILE=default

# AWS region where Bedrock + Athena are deployed
AWS_REGION=eu-west-2

# ── Athena (Data Source) ─────────────────────────────────────
ATHENA_DATABASE=test-gp-workforce
ATHENA_OUTPUT_S3=s3://test-athena-results-fingertips/
ATHENA_WORKGROUP=

# ── Bedrock AI Model ────────────────────────────────────────
# Amazon Nova Pro (cheaper, faster):
BEDROCK_CHAT_MODEL_ID=amazon.nova-pro-v1:0
# Claude Sonnet 4.5 (smarter, more expensive):
# BEDROCK_CHAT_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0

# ── API Key Authentication ───────────────────────────────────
# Set a secret key to protect your API. Only requests with
# the matching X-API-Key header will be allowed.
# LOCAL:  leave blank (auth disabled for dev)
# PRODUCTION: generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── CORS (Security) ─────────────────────────────────────────
# Comma-separated list of allowed origins
# LOCAL:      http://localhost:5173,http://127.0.0.1:5173
# PRODUCTION: https://insightsqi.cajagroup.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Rate Limiting ────────────────────────────────────────────
# Format: "N/minute", "N/hour", "N/day"
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_SUGGESTIONS=30/minute
RATE_LIMIT_DEFAULT=60/minute

# ── Application Settings ────────────────────────────────────
LOG_LEVEL=INFO
REQUEST_TIMEOUT=90
AGENT_MAX_WORKERS=4
MAX_ROWS_RETURN=200
MAX_AGENT_LOOPS=3
MEMORY_MAX_TURNS=6
MAX_QUESTION_LENGTH=1000

# ── Cache TTLs (seconds) ────────────────────────────────────
SCHEMA_TTL_SECONDS=3600
LATEST_TTL_SECONDS=600
DISTINCT_TTL_SECONDS=1800
QUERY_CACHE_TTL=300

# ── File Paths ───────────────────────────────────────────────
DOMAIN_NOTES_PATH=gp_workforce_domain_notes.md
COLUMN_DICT_PATH=./schemas/column_dictionary.json
INDIVIDUAL_COLS_CSV=./schemas/individual_cols.csv
PRACTICE_DETAILED_COLS_CSV=./schemas/practice_detailed_cols.csv
PRACTICE_HIGH_COLS_CSV=./schemas/practice_high_cols.csv

# ── Optional: LangSmith Tracing ──────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_PROJECT=gp-workforce-chatbot
